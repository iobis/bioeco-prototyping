# Example environment file for BioEco Portal
#
# Copy this file to `.env` in the repository root and set real values.
# Docker Compose (dev and prod) and local scripts will read these variables.

# Elasticsearch superuser password (for user "elastic").
# REQUIRED for both dev and prod.
ELASTIC_PASSWORD=change-me-strong-password

# Optional overrides (usually not needed)
# ELASTICSEARCH_URL=http://localhost:9200
# DATA_DIR=/app/data
# CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

